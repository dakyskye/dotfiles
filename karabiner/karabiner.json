            "complex_modifications": {
                "rules": [
                    {
                        "description": "Caps Lock Hyper Layer (variable-based)",
                        "manipulators": [
                            {
                                "description": "Caps Lock = Hyper (hold)",
                                "type": "basic",
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [{ "set_variable": { "name": "hyper", "value": 1 } }],
                                "to_after_key_up": [{ "set_variable": { "name": "hyper", "value": 0 } }]
                            },

                            {
                                "description": "Caps+F → F17 (macOS Fill)",
                                "type": "basic",
                                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }],
                                "from": { "key_code": "f", "modifiers": { "optional": ["any"] } },
                                "to": [{ "key_code": "f17" }]
                            },
                            {
                                "description": "Caps+C → F18 (macOS Centre)",
                                "type": "basic",
                                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }],
                                "from": { "key_code": "c", "modifiers": { "optional": ["any"] } },
                                "to": [{ "key_code": "f18" }]
                            },

                            {
                                "description": "Caps+H moves a window to left half (ctrl+fn+left)",
                                "type": "basic",
                                "conditions": [{ "type": "variable_if", "name": "hyper", "value": 1 }],
